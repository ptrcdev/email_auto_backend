# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=email_auto
DATABASE_URL=postgresql://admin:admin@localhost:5432/email_auto

# Google OAuth (Gmail API - read-only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Separate redirect URI for Google Calendar OAuth (must also be registered in Google Cloud Console)
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/calendar/callback

# Microsoft OAuth (Graph API - read-only)
MICROSOFT_CLIENT_ID=
MICROSOFT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback

# LLM (OpenRouter) — comma-separated fallback chain, tried left to right
OPENROUTER_API_KEY=
LLM_MODELS=meta-llama/llama-3.3-70b-instruct:free,nvidia/nemotron-super-49b-v1:free,openrouter/auto

# WhatsApp Business API (Meta Cloud API) — ARCHIVED
# Re-activate when WhatsApp integration is enabled (requires Meta Business verification)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_TOKEN=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_TEMPLATE_NAME=
# WHATSAPP_TEMPLATE_LANG=en

# Email sending (Resend)
RESEND_API_KEY=
DIGEST_SENDER_EMAIL=digest@yourdomain.com
DIGEST_SENDER_NAME=Executive Inbox

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Web Push (VAPID keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:push@yourdomain.com

# App
PORT=3000
NODE_ENV=development
